body {
    font-family: sans-serif;
    display: flex;
    justify-content: center;
    background-color: #f4f4f9;
}

#viewer-container {
    width: 80%;
    max-width: 800px;
    margin-top: 50px;
    background: white;
    padding: 20px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

#viewer {
    border: 1px solid #ccc;
    margin: 20px 0;
    height: 600px;
}

.controls {
    display: flex;
    justify-content: space-between;
}

button {
    padding: 10px 20px;
    cursor: pointer;
}
