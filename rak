.grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.book-card {
    background: #fff;
    padding: 15px;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    text-align: center;
}

.book-card h3 {
    font-size: 1rem;
    margin-bottom: 5px;
}

.book-card button {
    margin-top: 10px;
    width: 100%;
}
